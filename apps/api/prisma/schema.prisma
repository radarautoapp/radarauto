generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  lojista
  funcionario
  revendedor
  admin
}

enum Plan {
  free
  premium
}

enum SubscriptionStatus {
  active
  cancelled
  past_due
  trialing
}

enum SubscriptionCycle {
  monthly
  quarterly
  yearly
}

enum ListingStatus {
  DRAFT
  PENDING
  ACTIVE
  INACTIVE
  EXPIRED
  SOLD
  BLOCKED
}

enum LeadScore {
  COLD
  WARM
  HOT
}

enum VerificationChannel {
  email
  phone
}

enum UserStatus {
  PENDING_ACTIVATION
  ACTIVE
}

model User {
  id                 String              @id @default(uuid())
  email              String              @unique
  passwordHash       String?
  name               String
  phone              String?
  cpf                String?             @unique
  role               UserRole            @default(revendedor)
  plan               Plan                @default(free)
  subscriptionStatus SubscriptionStatus?
  subscriptionCycle  SubscriptionCycle?
  storeId            String?
  active             Boolean             @default(true)

  status             UserStatus          @default(ACTIVE)
  invitedById        String?

  store              Store?              @relation(fields: [storeId], references: [id])
  invitedBy          User?               @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedUsers       User[]              @relation("InvitedBy")
  employeeInvites    EmployeeInvite[]
  createdListings    Listing[]           @relation("CreatedListings")
  approvedListings   Listing[]           @relation("ApprovedListings")
  sessions           Session[]

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?

  @@index([email])
  @@index([storeId])
  @@index([status])
  @@index([invitedById])
  @@index([deletedAt])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  ipAddress    String?
  userAgent    String?
  deviceLabel  String?

  lastSeenAt   DateTime @default(now())
  expiresAt    DateTime

  createdAt    DateTime @default(now())
  revokedAt    DateTime?

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Verification {
  id          String              @id @default(uuid())
  channel     VerificationChannel
  target      String
  codeHash    String
  attempts    Int                 @default(0)
  expiresAt   DateTime
  verifiedAt  DateTime?
  ipAddress   String?
  createdAt   DateTime            @default(now())

  @@index([channel, target, verifiedAt])
  @@index([expiresAt])
}

model Store {
  id          String   @id @default(uuid())
  name        String
  initials    String
  cnpj        String   @unique
  legalName   String?
  tradeName   String?
  phone       String
  whatsapp    String?
  email       String?
  city        String
  state       String
  since       Int
  rating      Float    @default(0)
  reviews     Int      @default(0)
  verified    Boolean  @default(false)
  description String?  @db.Text
  logoUrl     String?

  users       User[]
  vehicles    Vehicle[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([city, state])
  @@index([deletedAt])
  @@index([cnpj])
}

model Vehicle {
  id         String   @id @default(uuid())
  brand      String
  model      String
  version    String
  year       Int
  yearModel  Int
  km         Int
  fuel       String
  transm     String
  color      String
  colorHex   String
  plate      String?
  category   String
  price      Int
  fipe       Int
  city       String
  state      String
  optionals  String[] @default([])
  obs        String?  @db.Text
  photos     String[] @default([])
  delivery   Boolean  @default(false)

  storeId    String
  store      Store    @relation(fields: [storeId], references: [id])

  listing    Listing?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  @@index([storeId])
  @@index([brand, model])
  @@index([city, state])
  @@index([price])
  @@index([year])
  @@index([deletedAt])
}

model Listing {
  id            String        @id @default(uuid())
  vehicleId     String        @unique
  vehicle       Vehicle       @relation(fields: [vehicleId], references: [id])

  status        ListingStatus @default(DRAFT)
  rankingScore  Float         @default(0)
  views         Int           @default(0)
  favorites     Int           @default(0)

  createdById   String
  createdBy     User          @relation("CreatedListings", fields: [createdById], references: [id])

  approvedById  String?
  approvedBy    User?         @relation("ApprovedListings", fields: [approvedById], references: [id])
  approvedAt    DateTime?

  publishedAt   DateTime?
  expiresAt     DateTime?
  soldAt        DateTime?

  leads         Lead[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  @@index([status])
  @@index([rankingScore])
  @@index([createdById])
  @@index([deletedAt])
}

model Lead {
  id              String    @id @default(uuid())
  listingId       String
  listing         Listing   @relation(fields: [listingId], references: [id])

  visitorId       String
  name            String
  score           LeadScore @default(COLD)
  clicks          Int       @default(0)
  favorited       Boolean   @default(false)
  avgTimeSeconds  Int       @default(0)
  whatsappClicked Boolean   @default(false)
  telegramClicked Boolean   @default(false)
  lastSeen        DateTime  @default(now())

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  @@index([listingId])
  @@index([visitorId])
  @@index([score])
  @@index([lastSeen])
  @@index([deletedAt])
}

model AuditLog {
  id            String   @id @default(uuid())
  actorId       String?
  action        String
  resource      String
  resourceId    String
  before        Json?
  after         Json?
  correlationId String
  ip            String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([actorId])
  @@index([resource, resourceId])
  @@index([createdAt])
}

model EmployeeInvite {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
}

model Brand {
  id         String   @id @default(uuid())
  fipeCode   String   @unique
  name       String
  slug       String
  logoUrl    String?
  logoFormat String?
  popular    Boolean  @default(false)
  order      Int      @default(999)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([popular])
  @@index([order])
}
