# RADARAUTO — Variáveis de ambiente
# IMPORTANTE: copie este arquivo para .env.local e preencha
# NUNCA commitar .env (Regra 30)

# Environment
NODE_ENV=development

# ============ API ============
API_PORT=3001
API_HOST=localhost
API_URL=http://localhost:3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://radarauto:radarauto@localhost:5432/radarauto?schema=public

# Auth (JWT)
JWT_SECRET=change-me-in-production-use-a-vault
JWT_EXPIRES_IN=7d

# ============ WEB ============
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ============ External services (futuro) ============
# STRIPE_SECRET_KEY=
# SENTRY_DSN=
# RESEND_API_KEY=

# ============================================================
# Storage de arquivos (Sub-fase 3.5+)
# ============================================================

# local | supabase
# - local: salva em apps/api/uploads/ (default, dev)
# - supabase: usa Supabase Storage (prod)
STORAGE_PROVIDER=local

# Pasta de uploads quando STORAGE_PROVIDER=local (path relativo ao cwd da API)
LOCAL_STORAGE_ROOT=uploads

# Base URL da API (usado pra montar URLs publicas dos arquivos servidos via /uploads/*)
API_BASE_URL=http://localhost:3001

# Supabase (necessario quando STORAGE_PROVIDER=supabase)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_STORAGE_BUCKET=logos
