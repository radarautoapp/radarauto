# RADARAUTO — Variáveis de ambiente
# IMPORTANTE: copie este arquivo para .env.local e preencha
# NUNCA commitar .env (Regra 30)

# Environment
NODE_ENV=development

# ============ API ============
API_PORT=3001
API_HOST=localhost
API_URL=http://localhost:3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://radarauto:radarauto@localhost:5432/radarauto?schema=public

# Auth (JWT)
JWT_SECRET=change-me-in-production-use-a-vault
JWT_EXPIRES_IN=7d

# ============ WEB ============
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ============ External services (futuro) ============
# STRIPE_SECRET_KEY=
# SENTRY_DSN=
# RESEND_API_KEY=
